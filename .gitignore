Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================================
# Project-specific
# ============================================================================
# Corpora and datasets — usually large, often have their own licensing.
# Document in data/README.md where to download them.
data/corpora/*.txt
data/corpora/*.zip
data/corpora/*.gz
data/svm_datasets/
!data/corpora/.gitkeep
!data/svm_datasets/.gitkeep
!data/README.md

# Generated training artifacts (produced by phase1_extract / build_candidates)
data/*.cnd3
data/dict_combined.*

# Benchmark outputs
benchmark_results/
*.bench.json

# Generated docs
docs/_build/
docs/html/

# Logs
*.log
*.tmp

# Local environment / secrets (just in case)
.env
.env.local
secrets/

# Python (if/when we add Python tooling)
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node (if/when we add JS tooling)
node_modules/
package-lock.json
yarn.lock

# WASM build outputs
*.wasm
*.wat
bindings/wasm/build/